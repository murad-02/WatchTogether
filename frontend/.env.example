# Base URL of the NestJS REST API
NEXT_PUBLIC_API_URL=http://localhost:4000

# Base URL of the Socket.IO server (usually the same as the API)
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Optional TURN server for restrictive NATs (recommended for production)
# NEXT_PUBLIC_TURN_URL=turn:turn.example.com:3478
# NEXT_PUBLIC_TURN_USERNAME=user
# NEXT_PUBLIC_TURN_CREDENTIAL=pass
